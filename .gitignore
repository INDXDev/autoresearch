# Never commit real secrets / local env.
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/

# Generated reports (keep the folder via .gitkeep, ignore daily outputs).
outputs/*
!outputs/.gitkeep

# Prior-Issue digests generated at run time to de-duplicate research.
.research_context/

# Per-run page diffs Site Watch hands to Claude (ephemeral). The baselines in
# snapshots/ are NOT tracked on the default branch — together with the domain
# selection state they live on the dedicated orphan branch `auto-research-state`,
# so daily runs never pollute main's history. Keep the folder via .gitkeep;
# ignore the rendered baselines themselves.
.watch_diffs/
snapshots/*
!snapshots/.gitkeep
_snap_out/
_snapshots_incoming/

# Domain/language selection state, restored at run time from the
# `auto-research-state` orphan branch (never tracked on main).
.auto_state/
/selection.json

# Legacy static-site output dir (pre-Astro). Kept ignored for safety.
_site/

# Astro + Starlight site (site/): commit the SCAFFOLD only. Dependencies, build
# output, the Astro cache, and the content the exporter generates at run time
# (index.md + runs/ + items/ + sections/ + reactions/ + tags/ + the data file)
# are all regenerated by CI.
site/node_modules/
site/dist/
site/.astro/
site/src/content/docs/index.md
site/src/content/docs/runs/
site/src/content/docs/items/
site/src/content/docs/sections/
site/src/content/docs/reactions/
site/src/content/docs/tags/
site/src/data/meta.json

# OS / editor noise
.DS_Store
.idea/
.vscode/

# Local design notes (never part of the template; keep out of the public repo).
prompt.md

# Remotion source for the README tutorial video. The whole project is ignored —
# only the rendered output in /docs (tutorial.gif / .mp4) is committed.
/remotion/
