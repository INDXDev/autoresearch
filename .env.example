# Auto Research — example environment file.
#
# In GitHub Actions you do NOT need this file. Set these under
#   Settings > Secrets and variables > Actions   (Variables or Secrets).
# This file is only a reference for what each setting does. All values below
# are dummy placeholders. `.env` is gitignored and must never be committed.
#
# How it works: for each enabled section, the Claude Code Action web-searches
# and returns schema-validated JSON; a small Python script (no LLM) turns that
# JSON into a GitHub Issue. Add ONE Claude credential to turn it on.

# --- Feature flags (Variables) ---------------------------------------------
# Each section is an independent job. "true" (or unset) enables it; set to
# "false" to turn one off. Any subset can run.
ENABLE_RESEARCH_NEWS=true
ENABLE_HYPOTHESIS_GENERATION=true
ENABLE_RELATED_WORK=true
# Site Watch is a SECOND, independent pipeline (its own workflow): it renders the
# pages in config/watch_targets.json with Playwright, commits a snapshot of each
# to snapshots/, and when one changes, Claude summarises the diff into an Issue
# (+ Slack). "true"/unset enables it; "false" turns it off.
ENABLE_SITE_WATCH=true
# Optional: Playwright navigation timeout per page, in milliseconds (default 30000).
WATCH_TIMEOUT_MS=30000

# --- Output options (Variables) --------------------------------------------
# GitHub Issues are the default output: one labelled Issue per enabled section.
# Uses the built-in GITHUB_TOKEN. Set to "false" to turn Issues off.
ENABLE_GITHUB_ISSUE=true
# Also write one file per item, outputs/<date>-<section>-<n>.md, and upload them
# as an artifact (off by default).
ENABLE_FILE_OUTPUT=false
# Shared label(s) added to every Issue, comma-separated. Each section also gets
# its own tag: research-news / hypothesis / related-work.
GITHUB_ISSUE_LABELS=auto-research
# Bundle each section into a SINGLE Slack post (default true). Set to "false" to
# post one Slack message per item instead. Only matters when Slack is configured.
SLACK_DIGEST=true

# --- Output language (Variable or Secret) ----------------------------------
# "en" (default) or "ja". Sets both Claude's content language and the Markdown
# scaffolding language.
OUTPUT_LANGUAGE=en

# --- Research configuration (Variable) -------------------------------------
# Defaults to "AI" when unset. Claude also reads config/research_topics.md for
# extra context — set this to focus on something more specific.
RESEARCH_TOPIC=AI

# Roughly how many items to post per report (the average; Claude may go a few
# over or under). Defaults to 5. For related work it targets total papers.
ITEMS_PER_REPORT=5

# Optional: override the Claude model (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- De-duplication & feedback (Variables, optional) -----------------------
# Each run summarises prior Issues so Claude avoids repeating them. You can
# steer the next run by reacting 👍 / 👎 on a past Issue (or adding a label):
# EXISTING_CONTEXT_MAX  how many prior Issues to summarise (default 40).
# GOOD_LABELS / BAD_LABELS  label names that count as good/bad feedback,
#   comma-separated (defaults: good,👍,useful,approved / bad,👎,not-useful,rejected).
EXISTING_CONTEXT_MAX=40
# GOOD_LABELS=good,👍,useful,approved
# BAD_LABELS=bad,👎,not-useful,rejected

# --- Documentation site (Variables, optional) ------------------------------
# The "Publish Site" workflow reads ALL Issues back (with their labels/tags,
# reactions, and comments) and builds an Astro + Starlight site, then pushes it
# to the `gh-pages` branch. One-time setup: Settings > Pages > Source =
# "Deploy from a branch", Branch = "gh-pages" / "(root)".
# SITE_TITLE         heading shown in the site header (default "Auto Research").
# SITE_MAX_ISSUES    max Issues pulled per section label (default 300).
# SITE_FETCH_COMMENTS pull each Issue's comments onto its page (default true).
# SITE_TITLE=Auto Research
# SITE_MAX_ISSUES=300
# SITE_FETCH_COMMENTS=true
#
# SITE_BASE — the URL path the site is served under. By default it is derived
# from the repo name (PUBLIC project pages live at /<repo>/). But a PRIVATE
# repo's Pages are served at the ROOT of a random https://<id>.pages.github.io/
# domain — set SITE_BASE=/ in that case, or the CSS/JS 404 and the page looks
# unstyled. SITE_URL optionally overrides the canonical origin (sitemap/SEO only).
# SITE_BASE=/
# SITE_URL=https://example.pages.github.io
#
# Optional live comments + reactions on the site via giscus (GitHub
# Discussions). To enable: turn on Discussions, install the giscus GitHub App
# (https://github.com/apps/giscus), then copy the IDs from https://giscus.app
# into these repo Variables. Leave them unset for a fully static snapshot.
# GISCUS_REPO=owner/name
# GISCUS_REPO_ID=R_xxxxxxxx
# GISCUS_CATEGORY=Announcements
# GISCUS_CATEGORY_ID=DIC_xxxxxxxx
# GISCUS_LANG=en

# --- Credentials (Secrets) -------------------------------------------------
# Provide EITHER an API key OR a Claude Code OAuth token (create the latter with
# `claude setup-token`). If neither is set, every job still succeeds and prints
# a note telling you what to add.
ANTHROPIC_API_KEY=dummy
CLAUDE_CODE_OAUTH_TOKEN=dummy

# --- Slack (Secret, optional) ----------------------------------------------
# If unset / dummy, the Slack line is skipped (the run still succeeds).
# A real value looks like: https://hooks.slack.com/services/T000/B000/XXXX
SLACK_WEBHOOK_URL=dummy
